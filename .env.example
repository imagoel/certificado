# Credenciais do banco de dados
POSTGRES_DB=certificados
POSTGRES_USER=certificados
POSTGRES_PASSWORD=troque-esta-senha

# Portas publicadas no host (opcional para stacks via Portainer)
WEB_PORT=28754
API_PORT=29180

# Configuracoes da API
APP_ENV=production
CODE_PREFIX=ABC
PUBLIC_VALIDATION_BASE_URL=https://seu-dominio/validar
CERTIFICADOS_MAX_UPLOAD_BYTES=8388608
CERTIFICADOS_MAX_BATCH_ITEMS=500
TEMPLATES_MEDIA_DIR=/app/data/templates
TEMPLATES_MAX_UPLOAD_BYTES=10485760
SESSION_SECRET=troque-esta-chave-de-sessao
CERTIFICATE_HASH_SECRET=troque-esta-chave-do-certificado
SESSION_COOKIE_NAME=certificado_session
SESSION_SAME_SITE=lax
SESSION_HTTPS_ONLY=true
SESSION_MAX_AGE_SECONDS=43200
ENABLE_ADMIN_DOCS=false
TRUST_PROXY_HEADERS=true
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=900
LOGIN_BLOCK_SECONDS=900
CORS_ALLOW_ORIGINS=https://seu-dominio

# Bootstrap inicial opcional no startup da API
AUTO_SEED_SECRETARIAS=true
AUTO_BOOTSTRAP_ADMIN=true
BOOTSTRAP_ADMIN_NAME=Administrador
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=troque-esta-senha
